<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingBottom="100dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create New Post"
            android:textColor="#2196F3"
            android:textSize="22sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/myProfilePic"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="20dp"
            android:src="@drawable/editbox_background"
            android:padding="5dp"
            android:background="@drawable/editbox_background" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Skill you have:"
            android:textColor="#000000"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/postHave"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="5dp"
            android:background="@drawable/editbox_background"
            android:hint="e.g. PHP Development"
            android:padding="12dp"
            android:textColor="#000000" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text="Skill you want:"
            android:textColor="#000000"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/postWant"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="5dp"
            android:background="@drawable/editbox_background"
            android:hint="e.g. Android Development"
            android:padding="12dp"
            android:textColor="#000000" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text="Message (Optional):"
            android:textColor="#000000"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/postMsg"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginTop="5dp"
            android:background="@drawable/editbox_background"
            android:gravity="top"
            android:hint="Describe your offer..."
            android:padding="12dp"
            android:textColor="#000000" />

        <Button
            android:id="@+id/submitPostBtn"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="30dp"
            android:backgroundTint="#2196F3"
            android:text="Post to Dashboard"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />

    </LinearLayout>
</ScrollView>